# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and secrets
.env
.env.*
!.env.example

# Database files (app uses OS app data dir; ignore any in repo)
*.db
*.sqlite
*.sqlite3

# Local MCP config (may contain server commands/env; app uses OS app data dir)
mcp.json

# Editor and IDE
.vscode/*
!.vscode/extensions.json
.idea/
.cursor/

# OS
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust/Cargo (src-tauri has its own .gitignore; these are for any root-level Cargo)
/target/

# Test and coverage
coverage/
*.lcov
.nyc_output/

# Vite / dev
*.local

# Optional: lockfiles (uncomment if you want to ignore)
# pnpm-lock.yaml
# package-lock.json
# yarn.lock
